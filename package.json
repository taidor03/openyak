{
  "name": "openyak",
  "version": "1.1.10",
  "private": true,
  "license": "MIT",
  "description": "OpenYak — Your local AI assistant",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && ./venv/bin/python -m uvicorn app.main:create_app --factory --reload --reload-dir app --host 0.0.0.0 --port 8090",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "build:frontend": "bash scripts/build-frontend.sh",
    "build:backend": "bash scripts/build-backend.sh",
    "sync:desktop-meta": "node scripts/sync-desktop-meta.mjs",
    "build:desktop": "npm run sync:desktop-meta && cd desktop-tauri && cargo tauri build",
    "preflight": "npm run preflight:ui",
    "preflight:ui": "cd frontend && npm run preflight:ui",
    "build:release": "bash scripts/build-release.sh",
    "build:release:clean": "bash scripts/build-release.sh --clean",
    "build:release:sign": "bash scripts/build-release.sh --sign --clean",
    "build:release:skip-tauri": "npm run build:frontend && npm run build:backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.0",
    "wait-on": "^8.0.0"
  }
}
